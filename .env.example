# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY: connexion à la base de données Supabase
# (Project Settings > API dans le dashboard Supabase). Sans ces deux variables,
# l'application fonctionne en mode LocalStorage local uniquement (aucune donnée
# partagée entre appareils).
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# Clés API des fournisseurs IA (facultatif) : utilisées uniquement comme repli
# si le propriétaire n'a pas encore entré sa propre clé dans Réglages > Assistant IA.
# En production, chaque entreprise choisit normalement son fournisseur et sa clé
# directement dans l'application (stockée dans la table "companies").
GEMINI_API_KEY="MY_GEMINI_API_KEY"
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
OPENAI_API_KEY="MY_OPENAI_API_KEY"
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
